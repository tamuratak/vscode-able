{
    "search.exclude": {
        "out/**": true,
    },
    "js/ts.tsdk.path": "./node_modules/typescript/lib",
    "js/ts.preferences.importModuleSpecifier": "relative",
    "js/ts.preferences.importModuleSpecifierEnding": "js",
    "able.taskWatcher": [
        {
            "name": "task-lint",
            "globPattern": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts"],
        },
        {
            "name": "abletask-task-test-json",
            "globPattern": ["src/**/*.ts", "test/**/*.ts"],
        }
    ]
}
